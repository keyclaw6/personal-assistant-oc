# Local secrets and runtime state
# dotenvx private keys stay outside Git; encrypted .env files are tracked.
.env.keys
.env.keys.*
*.local
*.secret
*.key
*.pem
secrets/*
!secrets/.gitkeep
!secrets/*.enc.json

# OpenClaw machine state
.openclaw/
state/*
!state/.gitkeep

# Cognee runtime state
.cognee_system/
.cognee_data/

# Dependencies
node_modules/

# Build artifacts
dist/
build/
*.log
__pycache__/
*.py[cod]

# Plugins build artifacts (keep dist/ for openclaw-messenger — needed at runtime)
!plugins/openclaw-messenger/dist/
plugins/openclaw-messenger/node_modules/

# Briefings (generated daily, kept in briefings/ only when useful)
albert/memory/life/briefings/*.md
!albert/memory/life/briefings/.gitkeep

# OS/editor noise
.DS_Store
Thumbs.db
.vscode/
.idea/
