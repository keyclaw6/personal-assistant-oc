{
  "schemaVersion": "memory-page/v1",
  "vaultMode": "isolated",
  "renderMode": "obsidian",
  "search": {
    "backend": "local",
    "corpus": "wiki",
    "script": "../scripts/memory-search.mjs",
    "format": "json"
  },
  "agentTools": {
    "facade": "../scripts/mem.mjs",
    "verbs": [
      "search",
      "get",
      "put",
      "check"
    ]
  },
  "context": {
    "includeCompiledDigestPrompt": true,
    "defaultEntry": "../memory/_compiled/SESSION_INDEX.md",
    "progressiveDisclosure": true,
    "layers": [
      "L0",
      "L1",
      "L2"
    ]
  },
  "render": {
    "preserveHumanBlocks": true,
    "createBacklinks": true,
    "createDashboards": true
  },
  "storage": {
    "vectorDatabase": false,
    "embeddingProvider": null
  },
  "privacy": {
    "stripPrivateTagsFromCompiledArtifacts": true
  }
}
