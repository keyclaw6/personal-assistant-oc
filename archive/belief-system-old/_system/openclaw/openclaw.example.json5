        heartbeat: {
          every: "24h",
          target: "last",
          lightContext: true,
          isolatedSession: true,
          prompt: "Read HEARTBEAT.md if it exists in the workspace. Follow it strictly. Do not infer or repeat old tasks from prior chats. If nothing needs attention, reply HEARTBEAT_OK."
        }
      },
      {
        id: "source-librarian",
