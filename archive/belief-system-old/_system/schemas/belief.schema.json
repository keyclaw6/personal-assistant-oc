{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Belief Record",
  "type": "object",
  "required": ["id", "slug", "title", "status", "current_belief", "desired_direction", "scores"],
  "properties": {
    "id": { "type": "string" },
    "slug": { "type": "string" },
    "title": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["candidate", "active", "testing", "integrated", "maintenance", "archived"]
    },
    "origin": { "type": "string" },
    "current_belief": { "type": "string" },
    "desired_direction": { "type": "string" },
    "protective_function": { "type": "string" },
    "cost": { "type": "string" },
    "replacement_candidates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "related_beliefs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "scores": {
      "type": "object",
      "required": ["clarity", "emotional_charge", "evidence_update", "behavioral_expression", "integration"],
      "properties": {
        "clarity": { "type": "integer", "minimum": 0, "maximum": 5 },
        "emotional_charge": { "type": "integer", "minimum": 0, "maximum": 5 },
        "evidence_update": { "type": "integer", "minimum": 0, "maximum": 5 },
        "behavioral_expression": { "type": "integer", "minimum": 0, "maximum": 5 },
        "integration": { "type": "integer", "minimum": 0, "maximum": 5 }
      },
      "additionalProperties": false
    },
    "completion": {
      "type": "object",
      "properties": {
        "completed": { "type": "boolean" },
        "completion_type": { "type": "string" },
        "date": { "type": "string" },
        "user_mark": { "type": "string" },
        "reopen_condition": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
