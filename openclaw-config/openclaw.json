{
    "agents": {
        "defaults": {
            "workspace": "<UPDATE_ON_NEW_MACHINE>/companion",
            "models": {
                "openrouter/deepseek/deepseek-v4-flash": {}
            },
            "model": {
                "primary": "openrouter/deepseek/deepseek-v4-flash"
            },
            "heartbeat": {
                "every": "0m"
            },
            "contextPruning": {
                "mode": "cache-ttl",
                "ttl": "15m",
                "keepLastAssistants": 6,
                "minPrunableToolChars": 50000,
                "softTrimRatio": 0.3,
                "hardClearRatio": 0.5,
                "softTrim": {
                    "maxChars": 4000
                },
                "hardClear": {
                    "enabled": true
                }
            },
            "compaction": {
                "mode": "safeguard",
                "reserveTokensFloor": 140000,
                "keepRecentTokens": 50000,
                "truncateAfterCompaction": true,
                "memoryFlush": {
                    "enabled": true,
                    "softThresholdTokens": 20000,
                    "systemPrompt": "Session is nearing compaction. Save only durable user facts, commitments, corrections, decisions, preferences, and open loops to Companion memory files. Keep facts separate from hypotheses. Reply NO_REPLY if nothing durable should be saved.",
                    "prompt": "Pre-compaction memory flush. GPT-5.5 has a 400K context window but the effective OpenAI compaction boundary is about 260K tokens because of output reserve. Before compaction, write durable information to memory/observations/YYYY-MM.md, memory/life/commitments.md, memory/conflicts.md, or relevant pattern/belief staging files. Do not save speculation as truth. Reply NO_REPLY if nothing durable should be saved."
                }
            }
        },
        "list": [
            {
                "id": "main",
                "identity": {
                    "name": "Companion"
                }
            }
        ]
    },
    "gateway": {
        "mode": "local",
        "auth": {
            "mode": "token",
            "token": "<GENERATE_NEW_TOKEN>"
        },
        "port": 18789,
        "bind": "loopback",
        "tailscale": {
            "mode": "off",
            "resetOnExit": false
        },
        "controlUi": {
            "allowInsecureAuth": false,
            "allowedOrigins": [
                "http://localhost:18789",
                "http://127.0.0.1:18789"
            ]
        },
        "remote": {
            "token": "<GENERATE_NEW_TOKEN>"
        },
        "trustedProxies": [
            "127.0.0.1",
            "::1"
        ]
    },
    "meta": {
        "lastTouchedVersion": "2026.4.25",
        "lastTouchedAt": "2026-05-11T18:00:00.000Z"
    },
    "session": {
        "dmScope": "per-channel-peer"
    },
    "tools": {
        "profile": "default",
        "alsoAllow": [
            "composio-limited",
            "composio_status",
            "composio_gmail_personal",
            "composio_gmail_work",
            "composio_calendar",
            "composio_tasks",
            "composio_linkedin"
        ],
        "web": {
            "search": {
                "provider": "tavily",
                "enabled": true
            }
        }
    },
    "plugins": {
        "allow": [
            "openrouter",
            "tavily",
            "cognee-openclaw",
            "memory-core",
            "messenger",
            "composio-limited",
            "device-pair",
            "phone-control",
            "talk-voice"
        ],
        "deny": [
            "acpx"
        ],
        "entries": {
            "acpx": {
                "enabled": false
            },
            "openrouter": {
                "enabled": true
            },
            "tavily": {
                "enabled": true,
                "config": {
                    "webSearch": {
                        "apiKey": "<TAVILY_API_KEY>"
                    }
                }
            },
            "bonjour": {
                "enabled": false
            },
            "messenger": {
                "enabled": true,
                "config": {
                    "webhookPath": "/messenger/webhook",
                    "pageAccessToken": "<MESSENGER_PAGE_ACCESS_TOKEN>",
                    "appSecret": "<MESSENGER_APP_SECRET>",
                    "verifyToken": "<MESSENGER_VERIFY_TOKEN>"
                }
            },
            "composio-limited": {
                "enabled": true
            },
            "browser": {
                "enabled": false
            }
        }
    },
    "wizard": {
        "lastRunAt": "2026-05-11T18:00:00.000Z",
        "lastRunVersion": "2026.4.25",
        "lastRunCommand": "onboard",
        "lastRunMode": "local"
    }
}
