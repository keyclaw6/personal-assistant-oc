# Delphi paper trader — crontab (adjust REPO path; install with `crontab -e`)
# Prereqs: `mkdir -p ~/personal-assistant-oc/delphi/tmp`, dotenvx, logged-in codex CLI.
#
# F4: ALL state-mutating jobs serialize on ONE shared lock (tmp/state.lock).
# Heartbeat uses -n (skip if busy — next tick is 10 min away); the others wait.

REPO=/Users/kristian/personal-assistant-oc
LOCK=delphi/tmp/state.lock

# Heartbeat sweep + judge, every 10 minutes (PROGRAM §2)
*/10 * * * * cd $REPO && flock -n $LOCK -c 'dotenvx run -f .env.delphi -- python3 delphi/scripts/heartbeat.py --domain ai-releases && dotenvx run -f .env.delphi -- python3 delphi/scripts/judge.py --domain ai-releases' >> delphi/tmp/cron.log 2>&1

# Orchestrator — hourly maintenance pass (PROGRAM §6)
3 * * * * cd $REPO && flock -w 900 $LOCK -c 'dotenvx run -f .env.delphi -- python3 delphi/scripts/orchestrator.py' >> delphi/tmp/cron.log 2>&1

# Resolver, every 6 hours
17 */6 * * * cd $REPO && flock -w 900 $LOCK -c 'dotenvx run -f .env.delphi -- python3 delphi/scripts/resolve.py --domain ai-releases' >> delphi/tmp/cron.log 2>&1

# Explorer — KICKSTART cadence (every 3 h) while config.kickstart is active.
# After kickstart, comment this line and use the daily line below.
7 */3 * * * cd $REPO && flock -w 1800 $LOCK -c 'dotenvx run -f .env.delphi -- python3 delphi/scripts/explorer.py --domain ai-releases' >> delphi/tmp/cron.log 2>&1
# Post-kickstart daily explorer:
# 7 6 * * * cd $REPO && flock -w 1800 $LOCK -c 'dotenvx run -f .env.delphi -- python3 delphi/scripts/explorer.py --domain ai-releases' >> delphi/tmp/cron.log 2>&1

# Daily state snapshot — commits ONLY delphi/ paths (isolation, PROGRAM §0)
49 20 * * * cd $REPO && flock -w 900 $LOCK -c 'git add delphi && (git diff --cached --quiet || git commit -m "delphi: daily state snapshot")' >> delphi/tmp/cron.log 2>&1
