{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "p_yes",
    "confidence",
    "rationale",
    "lessons"
  ],
  "properties": {
    "p_yes": {
      "type": "number",
      "exclusiveMinimum": 0,
      "exclusiveMaximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1,
      "maxLength": 2000
    },
    "lessons": {
      "type": "array",
      "maxItems": 3,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 500
      }
    }
  }
}
