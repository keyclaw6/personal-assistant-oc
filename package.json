{
  "name": "personal-assistant-oc",
  "version": "0.1.0",
  "private": true,
  "description": "Albert — Kristian's Messenger-first personal assistant for life ops, memory, and evidence-backed self-development.",
  "type": "module",
  "scripts": {
    "gws": "node scripts/gws.mjs",
    "brief": "node scripts/morning-brief.mjs",
    "brief:dry": "node scripts/morning-brief.mjs --dry-run",
    "journal:status": "node scripts/evening-journal.mjs --status",
    "journal:message": "node scripts/evening-journal.mjs --message",
    "journal:send": "node scripts/evening-journal.mjs --send",
    "review:nightly:message": "node scripts/nightly-dream.mjs --message",
    "review:nightly:status": "node scripts/nightly-dream.mjs --status",
    "dream:message": "node scripts/nightly-dream.mjs --message",
    "dream:status": "node scripts/nightly-dream.mjs --status",
    "test:e2e:scripts": "node --test test/e2e/*.test.mjs",
    "test": "npm run test:e2e:scripts",
    "cognee": "bash scripts/cognee-server.sh",
    "hermes:migrate": "node scripts/hermes-migrate-local.mjs",
    "secrets:export": "node scripts/secrets-export.mjs",
    "secrets:import": "node scripts/secrets-import.mjs",
    "repo:check": "node scripts/repo-check.mjs",
    "check": "npm run repo:check"
  },
  "engines": {
    "node": ">=22.14.0"
  }
}
